#!/bin/bash
exec > /var/log/userdata.log 2>&1

# =========================
# BASE
# =========================
apt-get update -y
DEBIAN_FRONTEND=noninteractive apt-get install -y \
  apache2 curl unzip wget git snapd ruby-full

# =========================
# PHP + EXTENSIONES
# =========================
apt-get install -y php php-cli php-mysql php-xml \
  php-mbstring php-curl php-zip php-bcmath php-intl \
  libapache2-mod-php

# =========================
# COMPOSER
# =========================
export HOME=/root
curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer
ln -sf /usr/local/bin/composer /usr/bin/composer

# =========================
# APACHE MODULES
# =========================
a2enmod rewrite ssl headers
systemctl enable apache2

# =========================
# VHOST APACHE PARA LARAVEL
# =========================
cat > /etc/apache2/sites-available/techuniverse.conf << 'EOF'
<VirtualHost *:80>
    ServerName backend.techuniverse.local
    DocumentRoot /var/www/api/public

    <Directory /var/www/api/public>
        AllowOverride All
        Require all granted
        Options -Indexes +FollowSymLinks
    </Directory>

    ErrorLog /var/log/apache2/backend-error.log
    CustomLog /var/log/apache2/backend-access.log combined
</VirtualHost>
EOF

a2ensite techuniverse.conf
a2dissite 000-default.conf

# =========================
# APP DIR
# =========================
mkdir -p /var/www/api
chown -R www-data:www-data /var/www/api

# =========================
# ENV BASE
# =========================
cat > /var/www/.env.base << EOF
APP_ENV=production
APP_DEBUG=false
APP_KEY=

APP_URL=https://techuniverse3.duckdns.org
ASSET_URL=https://techuniverse3.duckdns.org

DB_CONNECTION=mysql
DB_HOST=${DB_HOST}
DB_PORT=3306
DB_DATABASE=techuniverse
DB_USERNAME=root
DB_PASSWORD=${DB_ROOT_PASSWORD}

FILAMENT_FILESYSTEM_DISK=public
EOF

systemctl restart apache2

# =========================
# CODEDEPLOY AGENT
# =========================
cd /tmp
curl -O https://aws-codedeploy-us-east-1.s3.us-east-1.amazonaws.com/latest/install
chmod +x install
./install auto
systemctl enable codedeploy-agent
systemctl start codedeploy-agent